# ============================================
# Environment  (development | staging | production)
# ============================================
APP_ENV=development

# ============================================
# Application
# ============================================
APP_HOST=0.0.0.0
APP_PORT=8000
APP_TITLE=FastAPI Template
APP_DESCRIPTION=A modular FastAPI project template
APP_VERSION=1.0.0
API_PREFIX=/api/v1

# ============================================
# Logging
# ============================================
LOG_WRITE_TO_FILE=true
LOG_FOLDER=app/logs/logs_data
LOG_ROTATION=200MB
LOG_RETENTION=7days

# ============================================
# Auth / Access control
# ============================================
SUPERUSER_USERNAME=admin

# ============================================
# MongoDB
# ============================================
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_USERNAME=admin
MONGODB_PASSWORD=password
MONGODB_AUTH=admin
MONGODB_EXTERNAL_PORT=27017

# ============================================
# Redis
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=password
REDIS_EXTERNAL_PORT=6379

# ============================================
# Auth / JWT
# ============================================
AUTH_SECRET_KEY=your-secret-key-change-me
AUTH_ALGORITHM=HS256
AUTH_EXPIRE_SECONDS=3600
